{% assign member_links = include.links %}
{% if member_links %}
  <div class="member-links">
    {% for link in member_links %}
      {% assign key = link[0] | downcase %}
      {% assign value = link[1] %}
      {% if value %}
        {% assign href = value %}
        {% assign label = link[0] %}
        {% if key == "email" %}
          {% assign href = "mailto:" | append: value %}
          {% assign label = "Email" %}
        {% elsif key == "github" %}
          {% unless value contains "://" %}
            {% assign href = "https://github.com/" | append: value %}
          {% endunless %}
          {% assign label = "GitHub" %}
        {% elsif key == "home-page" or key == "website" %}
          {% assign label = "Website" %}
        {% elsif key == "linkedin" %}
          {% unless value contains "://" %}
            {% assign href = "https://www.linkedin.com/in/" | append: value %}
          {% endunless %}
          {% assign label = "LinkedIn" %}
        {% elsif key == "google-scholar" %}
          {% unless value contains "://" %}
            {% assign href = "https://scholar.google.com/citations?user=" | append: value %}
          {% endunless %}
          {% assign label = "Scholar" %}
        {% elsif key == "orcid" %}
          {% unless value contains "://" %}
            {% assign href = "https://orcid.org/" | append: value %}
          {% endunless %}
          {% assign label = "ORCID" %}
        {% endif %}
        <a class="btn btn-sm btn-outline-primary me-1 mb-1" href="{{ href }}" target="_blank" rel="external nofollow noopener">{{ label }}</a>
      {% endif %}
    {% endfor %}
  </div>
{% endif %}
